# ===========================================
# KinvoxAI Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database ---
DATABASE_URL=postgresql://kinvoxai:kinvoxai@localhost:5432/kinvoxai

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# --- API Keys ---
# Paddle (Payment processing)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Anthropic Claude
CLAUDE_API_KEY=

# OpenAI DALL-E
OPENAI_API_KEY=

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=

# --- Auth (optional, for future use) ---
JWT_SECRET=change-me-to-a-random-secret
