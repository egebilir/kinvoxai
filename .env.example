# ===========================================
# KinvoxAI Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Server ---
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# --- API Keys ---
# Anthropic Claude (text generation)
CLAUDE_API_KEY=

# OpenAI DALL-E (image generation)
DALLE_API_KEY=

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=
