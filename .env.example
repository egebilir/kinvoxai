# ===========================================
# KinvoxAI Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Server ---
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# --- API Keys ---
# Anthropic Claude (text generation)
CLAUDE_API_KEY=
# Model to use (default: claude-haiku-4-5-20251001)
# See: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=

# Replicate (Stable Diffusion image generation)
REPLICATE_API_TOKEN=
# "sdxl" for stability-ai/sdxl ($0.0049/image, better prompt adherence) or
# unset/anything else for stability-ai/stable-diffusion ($0.0023/image, cheaper)
REPLICATE_IMAGE_MODEL=

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=

# --- System dependencies ---
# POST /api/assemble-videos shells out to the `ffmpeg` binary (not an npm
# package) to stitch scene clips together. Install it and make sure it's on
# PATH: apt-get install ffmpeg (Linux/WSL), brew install ffmpeg (macOS), or
# download a build for Windows and add its bin/ folder to PATH.
